PORT=3001
PACIFICA_API_URL=https://test-api.pacifica.fi/api/v1
ELFA_API_KEY=your_elfa_api_key_here
SOLANA_PRIVATE_KEY=your_base58_private_key
BACKEND_WALLET_ADDRESS=your_public_key
USDP_MINT=USDPqRbLidFGufty2s3oizmDEKdqx7ePTqzDMbf5ZKM
DATABASE_URL=./predica.db
# Comma-separated list of allowed FE origins for CORS. Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Set to "false" to disable LLM-backed sentiment (falls back to engagement proxy).
# Helpful to conserve Elfa chat credits during dev.
SENTIMENT_LLM_ENABLED=true
# Bearer token for /api/admin/* endpoints. If unset, admin routes return 503.
ADMIN_TOKEN=change_me_in_prod
# Web Push (browser notifications on market resolve). If unset, push is
# disabled and notification endpoints return 503 — the rest of the API works
# normally. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@predica.local
